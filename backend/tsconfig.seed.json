{
  "compilerOptions": {
    "outDir": "./dist/prisma",
    "rootDir": "./prisma",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2020",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["prisma/seed.ts"]
}
