generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Item {
  id        String   @id @default(uuid())
  name      String
  quantity  Int      @db.Integer
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("items")
}